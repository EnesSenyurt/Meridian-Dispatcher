{
  "title": "Meridian Dispatcher Traffic",
  "timezone": "browser",
  "refresh": "5s",
  "schemaVersion": 30,
  "panels": [
    {
      "type": "stat",
      "title": "Total Requests",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(dispatcher_requests_total)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Error Rate (5xx)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(dispatcher_requests_total{status=~\"5..\"}[1m])) / sum(rate(dispatcher_requests_total[1m])) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "type": "piechart",
      "title": "Traffic by Service",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (service) (dispatcher_requests_total)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Rate (Req/s)",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "sum by (status) (rate(dispatcher_requests_total[1m]))",
          "legendFormat": "Status {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Detailed Log Table (Pseudo Logger)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "dispatcher_log_entry",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "instance": true,
              "job": true
            }
          }
        }
      ]
    }
  ]
}